@{
    Layout = "_Layout";
    var bmi = ViewData["Bmi"] as double?;
    var category = ViewData["Category"] as string;
    var height = ViewData["Height"] as double?;
    var weight = ViewData["Weight"] as double?;
}

<!-- BMI Calculator Modal -->
<div class="modal fade" id="bmiModal" tabindex="-1" role="dialog" aria-labelledby="bmiModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="bmiModalLabel">Tính BMI</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form method="post" asp-action="Calculate" id="bmiForm">
                    <div class="form-group mb-3">
                        <label for="heightCm">Chiều cao (cm)</label>
                        <input type="number" id="heightCm" name="heightCm" class="form-control" value="@(height?.ToString() ?? "")" step="0.1" />
                    </div>
                    <div class="form-group mb-3">
                        <label for="weightKg">Cân nặng (kg)</label>
                        <input type="number" id="weightKg" name="weightKg" class="form-control" value="@(weight?.ToString() ?? "")" step="0.1" />
                    </div>

                    @if (ViewData["Error"] != null)
                    {
                        <div class="alert alert-danger mt-2">@ViewData["Error"]</div>
                    }

                    @if (bmi.HasValue)
                    {
                        <div class="alert alert-info mt-3">
                            <h5>Kết quả</h5>
                            <p>BMI: <strong>@String.Format("{0:0.00}", bmi)</strong></p>
                            <p>Phân loại: <strong>@category</strong></p>
                        </div>
                    }
                </form>
            </div>
            <div class="modal-footer">
                @if (bmi.HasValue)
                {
                    <a class="btn btn-success" href="/BepTruong?bmi=@(bmi.Value)">Chuyển sang tạo thực đơn</a>
                }
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="btn btn-primary" onclick="document.getElementById('bmiForm').submit()">Tính BMI</button>
            </div>
        </div>
    </div>
</div>

<div class="container mt-4">
    <button type="button" class="btn btn-primary btn-lg" data-bs-toggle="modal" data-bs-target="#bmiModal">
        Mở Tính BMI
    </button>
</div>

<script>
    // Auto-open modal if there are errors or results
    document.addEventListener('DOMContentLoaded', function() {
        @if ((ViewData["Error"] != null || bmi.HasValue))
        {
            <text>
                var bmiModal = new bootstrap.Modal(document.getElementById('bmiModal'));
                bmiModal.show();
            </text>
        }
    });
</script>
