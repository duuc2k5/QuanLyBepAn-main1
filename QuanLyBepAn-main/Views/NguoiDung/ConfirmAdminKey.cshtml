@{
    ViewData["Title"] = "Xác Nhận Key Admin";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-lock"></i> Xác Nhận Admin Key
                    </h4>
                </div>
                <div class="card-body">
                    <p class="text-muted">
                        Bạn đang tạo tài khoản với quyền <strong>Admin</strong>. 
                        Vui lòng nhập Admin Security Key để tiếp tục.
                    </p>

                    @if (!string.IsNullOrEmpty(ViewBag.Error))
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fas fa-exclamation-circle"></i> @ViewBag.Error
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <div class="alert alert-info">
                        <strong>Tên đăng nhập:</strong> @ViewBag.TenDangNhap
                    </div>

                    <form asp-action="ConfirmAdminKey" method="post">
                        <div class="form-group">
                            <label for="AdminKey" class="form-label">Admin Security Key</label>
                            <input type="password" 
                                   name="AdminKey" 
                                   id="AdminKey" 
                                   class="form-control form-control-lg" 
                                   placeholder="Nhập Admin Security Key" 
                                   required 
                                   autofocus />
                            <small class="text-muted d-block mt-2">
                                <i class="fas fa-info-circle"></i> Key này được cấu hình bởi quản trị viên hệ thống
                            </small>
                        </div>

                        <div class="form-group mt-4">
                            <button type="submit" class="btn btn-danger btn-lg w-100">
                                <i class="fas fa-check"></i> Xác Nhận & Tạo Tài Khoản Admin
                            </button>
                        </div>
                    </form>

                    <div class="mt-3">
                        <a asp-action="Create" class="btn btn-secondary btn-sm w-100">
                            <i class="fas fa-arrow-left"></i> Quay Lại
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Focus vào input key khi load trang
        document.getElementById('AdminKey').focus();
    </script>
}
